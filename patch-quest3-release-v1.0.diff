diff --git a/src/util/u_gralloc/u_gralloc_fallback.c b/src/util/u_gralloc/u_gralloc_fallback.c
index 44fb32d8c..6d3df1029 100644
--- a/src/util/u_gralloc/u_gralloc_fallback.c
+++ b/src/util/u_gralloc/u_gralloc_fallback.c
@@ -13,6 +13,7 @@
 #include "util/log.h"
 #include "util/macros.h"
 #include "util/u_memory.h"
+#include "util/u_atomic.h"
 
 #include <dlfcn.h>
 #include <errno.h>
@@ -156,6 +157,17 @@ fallback_gralloc_get_buffer_info(struct u_gralloc *gralloc,
    }
 #endif
 
+   /* Quest 3 (HorizonOS): gralloc private data doesn't match the QTI 'gmsm'
+    * layout, leaving the modifier unknown, while the compositor treats these
+    * buffers as uncompressed linear (verified via SurfaceFlinger buffer
+    * dumps: mod=0, compressed=false). Rendering tiled into them produces
+    * full-screen corruption, so default to LINEAR when we don't know better.
+    */
+   if (out->modifier == DRM_FORMAT_MOD_INVALID) {
+      mesa_logi("gralloc: unknown private handle layout, assuming LINEAR");
+      out->modifier = DRM_FORMAT_MOD_LINEAR;
+   }
+
    return 0;
 }
 

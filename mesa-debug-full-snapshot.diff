 }
+
+#if DETECT_OS_ANDROID
+/* Q3DBG: dump presented swapchain frames to disk for offline inspection.
+ * The Quest compositor path cannot be screencaptured while the panel is
+ * off-view, so grab the raw linear frame at present time instead.
+ */
+VKAPI_ATTR VkResult VKAPI_CALL
+tu_QueueSignalReleaseImageANDROID(VkQueue _queue,
+                                  uint32_t waitSemaphoreCount,
+                                  const VkSemaphore *pWaitSemaphores,
+                                  VkImage _image,
+                                  int *pNativeFenceFd)
+{
+   VkResult result = vk_common_QueueSignalReleaseImageANDROID(
+      _queue, waitSemaphoreCount, pWaitSemaphores, _image, pNativeFenceFd);
+
+   static uint32_t q3dbg_present_n = 0;
+   static uint32_t q3dbg_dump_n = 0;
+   uint32_t n = p_atomic_inc_return(&q3dbg_present_n);

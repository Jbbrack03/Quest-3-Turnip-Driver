+   VK_FROM_HANDLE(tu_image, image, _image);
+   struct tu_device *dev = container_of(vkq->base.device, struct tu_device, vk);
+
+   vkq->base.device->dispatch_table.QueueWaitIdle(_queue);
+
+   if (!image->mem || !image->mem->bo) {
+      mesa_loge("Q3DBG framedump: no bound bo (present #%u)", n);
+      return result;
+   }
+
+   struct tu_bo *bo = image->mem->bo;
+   if (!bo->map && tu_bo_map(dev, bo, NULL) != VK_SUCCESS) {
+      mesa_loge("Q3DBG framedump: map failed (present #%u)", n);
+      return result;
+   }
+
+   const struct fdl_layout *l = &image->layout[0];
+   uint32_t pitch = fdl_pitch(l, 0);
+   uint32_t w = image->vk.extent.width;
+   uint32_t h = image->vk.extent.height;
+
+   char path[256];
+   snprintf(path, sizeof(path),
+            "/storage/emulated/0/Android/data/dev.eden.eden_emulator/files/q3dbg_frame_p%u_%ux%u_pitch%u_fmt%u_ubwc%d.raw",
+            n, w, h, pitch, (unsigned)l->format, image->ubwc_enabled ? 1 : 0);
+   FILE *f = fopen(path, "wb");
+   if (!f) {
+      mesa_loge("Q3DBG framedump: fopen failed errno=%d", errno);
+      return result;
+   }
+   const char *src = (const char *)bo->map + image->mem_offset;
+   fwrite(src, 1, MIN2((uint64_t)pitch * h, bo->size - image->mem_offset), f);
+   fclose(f);
+   p_atomic_inc_return(&q3dbg_dump_n);
+   mesa_loge("Q3DBG framedump: wrote %s (tile_mode=%u)", path, (unsigned)l->tile_mode);
+
+   return result;
+}
+#endif
+
